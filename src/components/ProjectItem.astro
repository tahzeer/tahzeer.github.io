---
import type { Project } from '../data/projects';
import SectionDivider from './SectionDivider.astro';
import StatusDot from './StatusDot.astro';

type Props = {
	project: Project;
};

const { project } = Astro.props;
const isActive = project.status === 'active';
const meta = [project.status, project.period].filter(Boolean).join(' / ');
---

<article class="mb-8">
	<div class="flex justify-between items-start gap-4 mb-1">
		<h2 class="font-medium flex items-center gap-2">
			{project.title}
			{isActive && <StatusDot label="active project" />}
		</h2>
		<span class="text-sm text-gray-500 shrink-0">{meta}</span>
	</div>

	<p class="text-gray-500 text-sm mb-2">{project.description}</p>
	<p class="text-gray-500 text-sm mb-2">stack: {project.stack.join(' · ')}</p>

	{project.links && project.links.length > 0 && (
		<div class="text-sm text-gray-500 flex flex-wrap gap-x-3 gap-y-1">
			{project.links.map((link) => (
				<a
					href={link.href}
					class="transition-all hover:text-neutral-800 dark:hover:text-neutral-200 underline decoration-gray-200 decoration-4 dark:decoration-gray-800"
					target={link.href.startsWith('http') ? '_blank' : undefined}
					rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
				>
					{link.label}
				</a>
			))}
		</div>
	)}
	<SectionDivider class="mt-6" />
</article>
