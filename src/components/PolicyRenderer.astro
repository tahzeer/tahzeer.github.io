---
import { site } from '../data/site';
import { formatDisplayDate, parseDateOnly } from '../lib/dates';
import { PROSE_CLASSES } from '../lib/prose';
import type { Policy } from '../lib/chromeExtensionPolicy';

interface Props {
	policy: Policy;
}

const { policy } = Astro.props;
---

<article>
	<header class="mb-10">
		<a
			href="/"
			class="text-sm text-gray-500 transition-all hover:text-neutral-800 dark:hover:text-neutral-200 inline-flex items-center gap-1"
		>
			<span aria-hidden="true">←</span> back to home
		</a>

		<h1 class="font-serif-accent text-xl tracking-tight mt-8 mb-2">{policy.title}</h1>

		<div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500">
			<time datetime={site.lastUpdated}>last updated: {formatDisplayDate(parseDateOnly(site.lastUpdated))}</time>
		</div>
	</header>

	<div class={PROSE_CLASSES}>
		{policy.sections.map((section) => (
			<section>
				<h2>{section.heading}</h2>
				{section.paragraphs.map((paragraph) => (
					<p set:html={paragraph} />
				))}
				{section.listItems && section.listItems.length > 0 && (
					<ul>
						{section.listItems.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				)}
			</section>
		))}
	</div>

</article>
