---
import { site } from '../data/site';
import { formatDate } from '../lib/dates';
import type { Policy } from '../lib/chromeExtensionPolicy';

interface Props {
	policy: Policy;
}

const { policy } = Astro.props;
---
<section class="mt-8 md:mt-10">
	<h1 class="text-xl md:text-2xl font-semibold tracking-tight">{policy.title}</h1>
	<p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
		Last updated: {formatDate(site.lastUpdated)}
	</p>

	<div class="mt-10 w-full h-px bg-zinc-600 dark:bg-zinc-600"></div>

	<div class="mt-6 space-y-6 leading-7 text-zinc-200 dark:text-zinc-400">
		{policy.sections.map((section) => (
			<section>
				<h2 class="text-xl font-medium">{section.heading}</h2>
				{section.paragraphs.map((paragraph) => (
					<p class="mt-2" set:html={paragraph} />
				))}
				{section.listItems && section.listItems.length > 0 && (
					<ul class="mt-2 list-disc list-inside space-y-1">
						{section.listItems.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				)}
			</section>
		))}
	</div>
</section>
