---
import StatusDot from './StatusDot.astro';

const { organization, designation, timeline, desc } = Astro.props;
const isCurrent = timeline.toLowerCase().includes("present");
---

<div>
  <div class="flex justify-between items-start mb-1">
    <h3 class="font-medium flex items-center gap-2">
      {organization}
      {isCurrent && <StatusDot label="current role" />}
    </h3>
    <span class="text-sm text-gray-500">{timeline}</span>
  </div>
  <p class="text-sm text-gray-500 mb-2">{designation}</p>
  <p class="text-gray-500 text-sm">{desc}</p>
</div>
