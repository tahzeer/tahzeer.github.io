---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
	src: ImageMetadata;
	alt?: string;
}

const { src, alt = 'Banner' } = Astro.props;
---

<Image
	src={src}
	alt={alt}
	class="w-full h-64 object-cover rounded-lg border border-zinc-200 dark:border-zinc-700"
	loading="eager"
/>
