---
const clientId = import.meta.env.SPOTIFY_CLIENT_ID ?? '';
const clientSecret = import.meta.env.SPOTIFY_CLIENT_SECRET ?? '';
const refreshToken = import.meta.env.SPOTIFY_REFRESH_TOKEN ?? '';
---

<span
    class="spotify-now-playing inline-flex items-center gap-4 text-sm text-gray-500"
    data-spotify
    data-spotify-client-id={clientId}
    data-spotify-client-secret={clientSecret}
    data-spotify-refresh-token={refreshToken}
>
    <img
        data-spotify-art
        src=""
        alt=""
        class="w-6 h-6 rounded-sm shrink-0 object-cover bg-zinc-100 dark:bg-zinc-800"
        style="display:none"
    />
    <span data-spotify-text class="truncate">loading...</span>
</span>

<script>
    (() => {
        const container = document.querySelector('[data-spotify]') as HTMLElement | null;
        const textEl = document.querySelector('[data-spotify-text]');
        const artEl = document.querySelector('[data-spotify-art]') as HTMLImageElement | null;
        if (!container || !textEl || !artEl) return;

        const CLIENT_ID = container.dataset.spotifyClientId || '';
        const CLIENT_SECRET = container.dataset.spotifyClientSecret || '';
        const REFRESH_TOKEN = container.dataset.spotifyRefreshToken || '';

        if (!CLIENT_ID || !CLIENT_SECRET || !REFRESH_TOKEN) {
            textEl.textContent = 'spotify is idle';
            return;
        }

        let accessToken = '';

        function escapeHtml(s: string) {
            return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        async function refreshAccessToken(): Promise<string> {
            const response = await fetch('https://accounts.spotify.com/api/token', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    Authorization: 'Basic ' + btoa(`${CLIENT_ID}:${CLIENT_SECRET}`),
                },
                body: new URLSearchParams({
                    grant_type: 'refresh_token',
                    refresh_token: REFRESH_TOKEN,
                }),
            });
            if (!response.ok) throw new Error('token refresh failed');
            const data = await response.json();
            return data.access_token;
        }

        function setArt(src: string | undefined) {
            if (src) {
                artEl!.src = src;
                artEl!.style.display = '';
            } else {
                artEl!.removeAttribute('src');
                artEl!.style.display = 'none';
            }
        }

        function renderNotPlaying(lastPlayed: { albumArt?: string; name?: string; artist?: string; url?: string } | null) {
            if (lastPlayed?.name) {
                setArt(lastPlayed.albumArt);
                const trackName = lastPlayed.url
                    ? `<a href="${escapeHtml(lastPlayed.url)}" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-800 dark:hover:text-neutral-200 transition-colors">${escapeHtml(lastPlayed.name)}</a>`
                    : escapeHtml(lastPlayed.name);
                textEl!.innerHTML = `last played: <span class="text-gray-600 dark:text-gray-400">${trackName}</span> &middot; ${escapeHtml(lastPlayed.artist || '')}`;
            } else {
                setArt(undefined);
                textEl!.textContent = 'spotify is idle';
            }
        }

        function renderPlaying(track: { albumArt?: string; name?: string; artist?: string; url?: string }) {
            setArt(track.albumArt);
            const trackName = track.url
                ? `<a href="${escapeHtml(track.url)}" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-800 dark:hover:text-neutral-200 transition-colors">${escapeHtml(track.name || 'unknown')}</a>`
                : escapeHtml(track.name || 'unknown');
            textEl!.innerHTML = `<span class="text-gray-600 dark:text-gray-400">${trackName}</span> &middot; ${escapeHtml(track.artist || 'unknown')}`;
        }

        async function fetchNowPlaying() {
            try {
                if (!accessToken) {
                    accessToken = await refreshAccessToken();
                }

                const [currentRes, recentRes] = await Promise.all([
                    fetch('https://api.spotify.com/v1/me/player/currently-playing', {
                        headers: { Authorization: `Bearer ${accessToken}` },
                    }),
                    fetch('https://api.spotify.com/v1/me/player/recently-played?limit=1', {
                        headers: { Authorization: `Bearer ${accessToken}` },
                    }),
                ]);

                if (currentRes.status === 401) {
                    accessToken = await refreshAccessToken();
                    return fetchNowPlaying();
                }

                if (currentRes.ok && currentRes.status !== 204) {
                    const data = await currentRes.json();
                    if (data.item) {
                        renderPlaying({
                            albumArt: data.item.album.images[0]?.url ?? '',
                            name: data.item.name,
                            artist: data.item.artists.map((a: any) => a.name).join(', '),
                            url: data.item.external_urls.spotify,
                        });
                        return;
                    }
                }

                if (recentRes.ok) {
                    const recent = await recentRes.json();
                    if (recent.items?.length > 0) {
                        const t = recent.items[0].track;
                        renderNotPlaying({
                            albumArt: t.album.images[0]?.url ?? '',
                            name: t.name,
                            artist: t.artists.map((a: any) => a.name).join(', '),
                            url: t.external_urls.spotify,
                        });
                        return;
                    }
                }

                renderNotPlaying(null);
            } catch {
                renderNotPlaying(null);
            }
        }

        fetchNowPlaying();
        setInterval(fetchNowPlaying, 30000);
    })();
</script>
